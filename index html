<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Landing Page</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

    <!-- ==================== NAVBAR ==================== -->
    <nav class="navbar" id="navbar">
        <div class="container nav-container">
            <a href="#" class="logo">My<span>Brand</span></a>
            <ul class="nav-links" id="navLinks">
                <li><a href="#home">Home</a></li>
                <li><a href="#features">Features</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#testimonials">Testimonials</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <div class="hamburger" id="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <!-- ==================== HERO SECTION ==================== -->
    <section class="hero" id="home">
        <div class="hero-overlay"></div>
        <div class="container hero-container">
            <div class="hero-content">
                <h1 class="hero-title fade-in">Bangun Sesuatu yang <span class="highlight">Luar Biasa</span></h1>
                <p class="hero-subtitle fade-in-delay">Solusi digital terbaik untuk membantu bisnis Anda berkembang lebih cepat dan lebih efisien.</p>
                <div class="hero-buttons fade-in-delay-2">
                    <a href="#contact" class="btn btn-primary">Mulai Sekarang</a>
                    <a href="#features" class="btn btn-outline">Pelajari Lebih</a>
                </div>
            </div>
        </div>
        <div class="scroll-indicator">
            <i class="fas fa-chevron-down"></i>
        </div>
    </section>

    <!-- ==================== FEATURES SECTION ==================== -->
    <section class="features" id="features">        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Fitur Unggulan</h2>
                <p class="section-subtitle">Kami menyediakan berbagai fitur terbaik untuk memenuhi kebutuhan Anda</p>
            </div>
            <div class="features-grid">
                <div class="feature-card" data-aos>
                    <div class="feature-icon">
                        <i class="fas fa-rocket"></i>
                    </div>
                    <h3>Performa Cepat</h3>
                    <p>Website yang dioptimalkan untuk kecepatan loading maksimal dan pengalaman pengguna terbaik.</p>
                </div>
                <div class="feature-card" data-aos>
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>Keamanan Terjamin</h3>
                    <p>Proteksi data berlapis dengan enkripsi terkini untuk menjaga keamanan informasi Anda.</p>
                </div>
                <div class="feature-card" data-aos>
                    <div class="feature-icon">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <h3>Responsif</h3>
                    <p>Tampilan sempurna di semua perangkat, dari desktop hingga smartphone.</p>
                </div>
                <div class="feature-card" data-aos>
                    <div class="feature-icon">
                        <i class="fas fa-palette"></i>
                    </div>
                    <h3>Desain Modern</h3>
                    <p>Antarmuka yang elegan dan intuitif untuk meningkatkan engagement pengguna.</p>
                </div>
                <div class="feature-card" data-aos>
                    <div class="feature-icon">
                        <i class="fas fa-cogs"></i>
                    </div>
                    <h3>Mudah Dikelola</h3>
                    <p>Dashboard admin yang user-friendly untuk mengelola konten dengan mudah.</p>
                </div>
                <div class="feature-card" data-aos>
                    <div class="feature-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h3>Support 24/7</h3>
                    <p>Tim support kami selalu siap membantu Anda kapan saja dibutuhkan.</p>
                </div>
            </div>
        </div>    </section>

    <!-- ==================== ABOUT SECTION ==================== -->
    <section class="about" id="about">
        <div class="container about-container">
            <div class="about-image" data-aos>
                <div class="image-placeholder">
                    <i class="fas fa-laptop-code"></i>
                </div>
            </div>
            <div class="about-content" data-aos>
                <h2 class="section-title">Tentang Kami</h2>
                <p>Kami adalah tim profesional yang berdedikasi untuk menciptakan solusi digital inovatif. Dengan pengalaman bertahun-tahun, kami telah membantu ratusan bisnis bertransformasi secara digital.</p>
                <ul class="about-list">
                    <li><i class="fas fa-check-circle"></i> Tim berpengalaman & profesional</li>
                    <li><i class="fas fa-check-circle"></i> Teknologi terkini & terpercaya</li>
                    <li><i class="fas fa-check-circle"></i> Harga kompetitif & transparan</li>
                    <li><i class="fas fa-check-circle"></i> Garansi kepuasan pelanggan</li>
                </ul>
                <a href="#contact" class="btn btn-primary">Hubungi Kami</a>
            </div>
        </div>
    </section>

    <!-- ==================== STATS SECTION ==================== -->
    <section class="stats">
        <div class="container stats-grid">
            <div class="stat-item" data-aos>
                <h3 class="stat-number" data-target="150">0</h3>
                <p>Proyek Selesai</p>
            </div>
            <div class="stat-item" data-aos>
                <h3 class="stat-number" data-target="80">0</h3>
                <p>Klien Puas</p>
            </div>
            <div class="stat-item" data-aos>
                <h3 class="stat-number" data-target="5">0</h3>
                <p>Tahun Pengalaman</p>
            </div>
            <div class="stat-item" data-aos>
                <h3 class="stat-number" data-target="24">0</h3>
                <p>Penghargaan</p>
            </div>
        </div>
    </section>

    <!-- ==================== TESTIMONIALS SECTION ==================== -->
    <section class="testimonials" id="testimonials">
        <div class="container">
            <div class="section-header">                <h2 class="section-title">Apa Kata Mereka</h2>
                <p class="section-subtitle">Testimoni dari klien yang telah menggunakan layanan kami</p>
            </div>
            <div class="testimonials-grid">
                <div class="testimonial-card" data-aos>
                    <div class="testimonial-stars">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p>"Layanan yang sangat luar biasa! Website kami sekarang jauh lebih cepat dan tampilannya sangat profesional."</p>
                    <div class="testimonial-author">
                        <div class="author-avatar">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="author-info">
                            <h4>Ahmad Rizky</h4>
                            <span>CEO, PT Maju Bersama</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card" data-aos>
                    <div class="testimonial-stars">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p>"Tim support sangat responsif dan membantu. Saya sangat merekomendasikan layanan ini untuk bisnis apapun."</p>
                    <div class="testimonial-author">
                        <div class="author-avatar">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="author-info">
                            <h4>Siti Nurhaliza</h4>
                            <span>Founder, Startup Digital</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card" data-aos>
                    <div class="testimonial-stars">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star-half-alt"></i>
                    </div>                    <p>"Proses pengerjaan cepat dan hasilnya melebihi ekspektasi. Terima kasih sudah membantu bisnis kami berkembang!"</p>
                    <div class="testimonial-author">
                        <div class="author-avatar">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="author-info">
                            <h4>Budi Santoso</h4>
                            <span>Manager, Toko Online</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== CTA SECTION ==================== -->
    <section class="cta">
        <div class="container cta-container">
            <h2>Siap Memulai Proyek Anda?</h2>
            <p>Konsultasikan kebutuhan Anda dengan tim kami sekarang. Gratis!</p>
            <a href="#contact" class="btn btn-primary btn-large">Konsultasi Gratis</a>
        </div>
    </section>

    <!-- ==================== CONTACT SECTION ==================== -->
    <section class="contact" id="contact">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Hubungi Kami</h2>
                <p class="section-subtitle">Punya pertanyaan? Jangan ragu untuk menghubungi kami</p>
            </div>
            <div class="contact-wrapper">
                <div class="contact-info" data-aos>
                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <h4>Alamat</h4>
                            <p>Jl. Contoh No. 123, Jakarta, Indonesia</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-envelope"></i>
                        <div>
                            <h4>Email</h4>
                            <p>hello@mybrand.com</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-phone-alt"></i>
                        <div>                            <h4>Telepon</h4>
                            <p>+62 812 3456 7890</p>
                        </div>
                    </div>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-github"></i></a>
                    </div>
                </div>
                <form class="contact-form" id="contactForm" data-aos>
                    <div class="form-group">
                        <input type="text" id="name" name="name" placeholder="Nama Lengkap" required>
                    </div>
                    <div class="form-group">
                        <input type="email" id="email" name="email" placeholder="Alamat Email" required>
                    </div>
                    <div class="form-group">
                        <input type="text" id="subject" name="subject" placeholder="Subjek">
                    </div>
                    <div class="form-group">
                        <textarea id="message" name="message" rows="5" placeholder="Pesan Anda..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fas fa-paper-plane"></i> Kirim Pesan
                    </button>
                </form>
            </div>
        </div>
    </section>

    <!-- ==================== FOOTER ==================== -->
    <footer class="footer">
        <div class="container footer-container">
            <div class="footer-col">
                <a href="#" class="footer-logo">My<span>Brand</span></a>
                <p>Solusi digital terbaik untuk bisnis Anda. Kami membantu Anda tumbuh dan berkembang di era digital.</p>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#features">Features</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-col">                <h4>Layanan</h4>
                <ul>
                    <li><a href="#">Web Development</a></li>
                    <li><a href="#">Mobile App</a></li>
                    <li><a href="#">UI/UX Design</a></li>
                    <li><a href="#">Digital Marketing</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Newsletter</h4>
                <p>Dapatkan update terbaru dari kami.</p>
                <form class="newsletter-form">
                    <input type="email" placeholder="Email Anda">
                    <button type="submit"><i class="fas fa-arrow-right"></i></button>
                </form>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 MyBrand. All rights reserved.</p>
        </div>
    </footer>

    <!-- ==================== BACK TO TOP ==================== -->
    <a href="#home" class="back-to-top" id="backToTop">
        <i class="fas fa-arrow-up"></i>
    </a>

    <script src="script.js"></script>
</body>
</html>
